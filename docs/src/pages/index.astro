---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
---

<StarlightPage
	frontmatter={{
		title: 'vLitejs — Fast & Lightweight JavaScript Player Library',
		description:
			'Fast and lightweight JavaScript library for customizing video and audio players. HTML5, YouTube, Vimeo, Dailymotion. 6 KB gzip. Zero dependency.',
		tableOfContents: false
	}}
>
	<div class="home">
		<!-- ==================== HERO ==================== -->
		<section class="home-hero">
			<img
				src="https://yoriiis.github.io/cdn/static/vlitejs/logo.svg"
				alt="vLitejs"
				class="home-hero-logo"
				width="80"
				height="80"
			/>
			<h1 class="home-hero-title">vLitejs</h1>
			<p class="home-hero-tagline">
				Fast & lightweight JavaScript library for customizing video and audio players
			</p>

			<div class="home-hero-badges">
				<a
					href="https://www.npmjs.com/package/vlitejs"
					class="home-hero-badge"
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="home-hero-badge-dot"></span>npm v8
				</a>
				<a
					href="https://bundlephobia.com/package/vlitejs"
					class="home-hero-badge"
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="home-hero-badge-dot"></span>6 KB gzip
				</a>
				<a
					href="https://github.com/vlitejs/vlite/blob/main/LICENSE"
					class="home-hero-badge"
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="home-hero-badge-dot"></span>MIT
				</a>
				<a
					href="https://github.com/vlitejs/vlite/actions/workflows/build.yml"
					class="home-hero-badge"
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="home-hero-badge-dot"></span>CI passing
				</a>
			</div>

			<div class="home-hero-actions">
				<a href="/getting-started" class="home-btn home-btn--primary">
					<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M8 0L6.59 1.41 12.17 7H0v2h12.17l-5.58 5.59L8 16l8-8z"></path>
					</svg>
					Get Started
				</a>
				<a
					href="https://github.com/vlitejs/vlite"
					class="home-btn home-btn--secondary"
					target="_blank"
					rel="noopener noreferrer"
				>
					<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
						></path>
					</svg>
					GitHub
				</a>
			</div>

			<div class="home-install">
				<code class="home-install-code" id="install-cmd">npm install vlitejs</code>
				<button class="home-install-copy" id="copy-install" aria-label="Copy install command" title="Copy">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
						<path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
					</svg>
				</button>
			</div>
		</section>

		<!-- ==================== DEMO ==================== -->
		<section class="home-demo">
			<p class="home-section-label">Interactive Demo</p>
			<h2 class="home-section-title">See it in action</h2>

			<nav class="home-demo-tabs" aria-label="Select provider">
				<button class="home-demo-tab is-active" data-key="html5-video">HTML5 Video</button>
				<button class="home-demo-tab" data-key="html5-audio">HTML5 Audio</button>
				<button class="home-demo-tab" data-key="youtube">YouTube</button>
				<button class="home-demo-tab" data-key="vimeo">Vimeo</button>
				<button class="home-demo-tab" data-key="dailymotion">Dailymotion</button>
			</nav>

			<div class="home-demo-player">
				<div id="demo-player-wrap"></div>
			</div>

			<p class="home-demo-credit" id="demo-credit" aria-live="polite"></p>
		</section>

		<!-- ==================== FEATURES ==================== -->
		<section class="home-features">
			<p class="home-section-label">Features</p>
			<h2 class="home-section-title">Everything you need</h2>

			<div class="home-features-grid">
				<div class="home-feature-card">
					<div class="home-feature-icon" aria-hidden="true">⚡</div>
					<h3>6 KB gzip</h3>
					<p>The lightest video player in its class. No performance tax on your app.</p>
				</div>
				<div class="home-feature-card">
					<div class="home-feature-icon" aria-hidden="true">◎</div>
					<h3>Zero dependency</h3>
					<p>Written in native JavaScript. No external framework required.</p>
				</div>
				<div class="home-feature-card">
					<div class="home-feature-icon" aria-hidden="true">▶</div>
					<h3>Provider API</h3>
					<p>HTML5, YouTube, Vimeo, Dailymotion — or build your own custom provider.</p>
				</div>
				<div class="home-feature-card">
					<div class="home-feature-icon" aria-hidden="true">⊕</div>
					<h3>Plugin API</h3>
					<p>Extend with subtitle, PiP, Cast, AirPlay, IMA and more official plugins.</p>
				</div>
				<div class="home-feature-card">
					<div class="home-feature-icon" aria-hidden="true">⊞</div>
					<h3>CSS customizable</h3>
					<p>Fine-grained design control via CSS custom properties scoped to the player.</p>
				</div>
				<div class="home-feature-card">
					<div class="home-feature-icon" aria-hidden="true">⊛</div>
					<h3>Accessible</h3>
					<p>W3C and A11Y compliant out of the box. Keyboard navigation supported.</p>
				</div>
			</div>
		</section>

		<!-- ==================== COMPARISON ==================== -->
		<section class="home-comparison">
			<p class="home-section-label">Benchmarks</p>
			<h2 class="home-section-title">The lightest in its class</h2>
			<p class="home-comparison-note">Gzip bundle size — smaller is better</p>

			<div class="home-comparison-chart">
				<div class="home-comparison-row">
					<span class="home-comparison-name">vlitejs</span>
					<div class="home-comparison-track" title="6 KB gzip">
						<div class="home-comparison-bar home-comparison-bar--vlitejs" style="width: 3.8%">
							6 KB
						</div>
					</div>
				</div>
				<div class="home-comparison-row">
					<span class="home-comparison-name">plyr</span>
					<div class="home-comparison-track" title="32 KB gzip">
						<div class="home-comparison-bar home-comparison-bar--plyr" style="width: 20.1%">
							32 KB
						</div>
					</div>
				</div>
				<div class="home-comparison-row">
					<span class="home-comparison-name">video.js</span>
					<div class="home-comparison-track" title="159 KB gzip">
						<div class="home-comparison-bar home-comparison-bar--videojs" style="width: 100%">
							159 KB
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</StarlightPage>

<script>
	import Vlitejs from 'vlitejs'
	import VlitejsYoutube from 'vlitejs/providers/youtube.js'
	import VlitejsVimeo from 'vlitejs/providers/vimeo.js'
	import VlitejsDailymotion from 'vlitejs/providers/dailymotion.js'

	// ── Provider configs ────────────────────────────────────────────────────────
	const PROVIDERS: Record<
		string,
		{
			html: () => string
			provider: string
			options: Record<string, unknown>
			credit: string
		}
	> = {
		'html5-video': {
			html: () =>
				`<video crossorigin id="demo-player" src="https://yoriiis.github.io/cdn/static/vlitejs/demo-video-html5.mp4">` +
				`<track label="English" kind="subtitles" srclang="en" src="https://yoriiis.github.io/cdn/static/vlitejs/demo-video-html5-subtitle-en.vtt" default />` +
				`<track label="Français" kind="subtitles" srclang="fr" src="https://yoriiis.github.io/cdn/static/vlitejs/demo-video-html5-subtitle-fr.vtt" />` +
				`</video>`,
			provider: 'html5',
			options: {
				poster: 'https://yoriiis.github.io/cdn/static/vlitejs/demo-poster.jpg',
				autoHide: true,
				bigPlay: true,
				playsinline: true
			},
			credit: '© The Jungle Book — Walt Disney Animation Studios'
		},
		'html5-audio': {
			html: () =>
				`<audio id="demo-player" src="https://yoriiis.github.io/cdn/static/vlitejs/demo-audio-html5.mp3"></audio>`,
			provider: 'html5',
			options: {},
			credit: '© Dreams — Bensound'
		},
		youtube: {
			html: () => `<div id="demo-player" data-youtube-id="43TH3PKNc_c"></div>`,
			provider: 'youtube',
			options: {
				poster: 'https://yoriiis.github.io/cdn/static/vlitejs/demo-poster.jpg',
				autoHide: true,
				bigPlay: true
			},
			credit: '© The Jungle Book — Walt Disney Animation Studios'
		},
		vimeo: {
			html: () => `<div id="demo-player" data-vimeo-id="162391385"></div>`,
			provider: 'vimeo',
			options: { autoHide: true },
			credit: '© The Jungle Book — Walt Disney Animation Studios'
		},
		dailymotion: {
			html: () => `<div id="demo-player" data-dailymotion-id="x88trc6"></div>`,
			provider: 'dailymotion',
			options: { autoHide: true },
			credit: '© The Jungle Book — Walt Disney Animation Studios'
		}
	}

	// ── State ───────────────────────────────────────────────────────────────────
	let playerInstance: InstanceType<typeof Vlitejs> | null = null

	// ── Register providers ───────────────────────────────────────────────────────
	Vlitejs.registerProvider('youtube', VlitejsYoutube)
	Vlitejs.registerProvider('vimeo', VlitejsVimeo)
	Vlitejs.registerProvider('dailymotion', VlitejsDailymotion)

	// ── Init player ──────────────────────────────────────────────────────────────
	function initPlayer(key: string) {
		const config = PROVIDERS[key]
		if (!config) return

		const wrap = document.getElementById('demo-player-wrap')
		const credit = document.getElementById('demo-credit')
		if (!wrap) return

		wrap.innerHTML = config.html()

		playerInstance = new Vlitejs('#demo-player', {
			options: config.options,
			provider: config.provider
		})

		if (credit) credit.textContent = config.credit
	}

	function destroyPlayer() {
		if (playerInstance) {
			playerInstance.destroy()
			playerInstance = null
		}
	}

	// ── Tabs ─────────────────────────────────────────────────────────────────────
	const tabs = document.querySelectorAll<HTMLButtonElement>('.home-demo-tab')

	tabs.forEach((tab) => {
		tab.addEventListener('click', () => {
			const key = tab.dataset.key
			if (!key || tab.classList.contains('is-active')) return

			tabs.forEach((t) => t.classList.remove('is-active'))
			tab.classList.add('is-active')

			destroyPlayer()
			initPlayer(key)
		})
	})

	// ── Copy install command ─────────────────────────────────────────────────────
	const copyBtn = document.getElementById('copy-install')
	const installCmd = document.getElementById('install-cmd')

	copyBtn?.addEventListener('click', async () => {
		if (!installCmd) return
		try {
			await navigator.clipboard.writeText(installCmd.textContent ?? '')
			copyBtn.innerHTML =
				'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff7f15" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>'
			setTimeout(() => {
				copyBtn.innerHTML =
					'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg>'
			}, 2000)
		} catch {}
	})

	// ── Initial load ─────────────────────────────────────────────────────────────
	initPlayer('html5-video')
</script>
